# Cổng chạy app
PORT=3000

# Đường dẫn đến Firebase Realtime Database (Tùy chọn, thường tự nhận diện từ serviceAccountKey.json)
# FIREBASE_DATABASE_URL=https://<TEN-PROJECT-CUA-BAN>.firebaseio.com


# Bật gửi thật qua Zalo OA. Để false khi test nội bộ.
ZALO_ENABLED=false

# dry-run: chỉ ghi log, không gọi API Zalo
# oa: gọi API Zalo OA
ZALO_MODE=dry-run

# Endpoint gửi tin tư vấn văn bản qua Zalo OA
ZALO_ENDPOINT=https://openapi.zalo.me/v3.0/oa/message/cs

# OA access token. Có thể nhập trong giao diện, nhưng dùng biến môi trường an toàn hơn.
ZALO_OA_ACCESS_TOKEN=

# Bật Coze AI cho chatbox. Để false nếu chỉ dùng trợ lý nội bộ.
AI_PROVIDER=internal

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

COZE_ENABLED=false
COZE_BASE_URL=https://api.coze.com
COZE_BOT_ID=
COZE_ACCESS_TOKEN=
COZE_USER_ID=bao-vang-teacher
